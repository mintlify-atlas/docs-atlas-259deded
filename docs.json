{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Anchor",
  "theme": "willow",
  "colors": {
    "primary": "#242b2c",
    "light": "#040404",
    "dark": "#242b2c"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/3b16fb27-22e9-4daa-a368-88b404b0d37e.svg",
    "dark": "https://media.brand.dev/3b16fb27-22e9-4daa-a368-88b404b0d37e.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/zhfahim/anchor"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/zhfahim/anchor"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "features"]
          },
          {
            "group": "Self Hosting",
            "pages": [
              "self-hosting/docker",
              "self-hosting/configuration",
              "self-hosting/database"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "authentication/local-auth",
              "authentication/oidc"
            ]
          },
          {
            "group": "Mobile App",
            "pages": ["mobile/android"]
          },
          {
            "group": "Admin Guide",
            "pages": [
              "admin/overview",
              "admin/user-management",
              "admin/settings"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["api-reference/overview", "api-reference/authentication"]
          },
          {
            "group": "Notes",
            "pages": [
              "api-reference/notes/list",
              "api-reference/notes/create",
              "api-reference/notes/get",
              "api-reference/notes/update",
              "api-reference/notes/delete",
              "api-reference/notes/sync",
              "api-reference/notes/bulk-actions"
            ]
          },
          {
            "group": "Tags",
            "pages": [
              "api-reference/tags/list",
              "api-reference/tags/create",
              "api-reference/tags/update",
              "api-reference/tags/delete"
            ]
          },
          {
            "group": "Note Sharing",
            "pages": [
              "api-reference/shares/list",
              "api-reference/shares/create",
              "api-reference/shares/update",
              "api-reference/shares/delete"
            ]
          },
          {
            "group": "Users",
            "pages": [
              "api-reference/users/me",
              "api-reference/users/profile",
              "api-reference/users/api-token"
            ]
          }
        ]
      }
    ]
  }
}
